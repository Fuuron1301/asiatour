DATABASE_URL=postgresql://postgres:postgres@localhost:55432/luxury_travel_next
ADMIN_SESSION_COOKIE=hlt_admin_session
ADMIN_SESSION_DAYS=7
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production

WORDPRESS_ADMIN_URL=http://localhost/wp-admin
# Optional legacy headless WordPress endpoint. Leave empty when using the built-in admin/local capture flow.
WORDPRESS_API_URL=
# Local lead/booking capture folder used when WORDPRESS_API_URL is empty.
LOCAL_CAPTURE_DIR=.local-data
ALLOW_DEMO_FALLBACK=false
ALLOW_STATIC_TOUR_CATALOG=false
CMS_CONTENT_RUNTIME=db
CMS_MENU_RUNTIME=db
CMS_THEME_RUNTIME=db
NEXT_PUBLIC_ALLOW_DEMO_FALLBACK=false
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=en
OPENCODEX_API_KEY=
OPENCODEX_BASE_URL=https://api.opencodex.co/v1
OPENCODEX_MODEL=gpt-5.5

# Mail SMTP example. Use Gmail app password or your SMTP provider password.
MAIL_ENABLED=1
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=587
MAIL_SMTP_SECURE=tls
MAIL_SMTP_USER=your-gmail-address@gmail.com
MAIL_SMTP_PASS=your-gmail-app-password
MAIL_FROM_EMAIL=your-gmail-address@gmail.com
MAIL_FROM_NAME=LPH Mobile POS
MAIL_TO=sales@example.com
MAIL_EXPOSE_LOGIN_LINK=1

# Legacy SMTP aliases are still supported.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=sendgrid_or_workspace_password
SMTP_FROM=booking@example.com
SMTP_TO=sales@example.com
SALES_NOTIFICATION_EMAIL=sales@example.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
GOOGLE_SITE_VERIFICATION=google-search-console-token
NEXT_PUBLIC_WHATSAPP_NUMBER=84901234567
NEXT_PUBLIC_USD_TO_VND_RATE=25000
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_RETURN_URL=http://localhost:3000/payment/vnpay-return
VIETQR_BANK_ID=
VIETQR_ACCOUNT_NO=
VIETQR_ACCOUNT_NAME=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_RETURN_URL=http://localhost:3000/payment/paypal-return
NEXT_REVALIDATION_SECRET=change-me-to-a-long-random-secret
WORDPRESS_REVALIDATION_URL=https://your-next-domain.com/api/revalidate
