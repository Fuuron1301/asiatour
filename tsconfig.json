{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "mobile-ss-ver2",
    "luxury-travel-next",
    "_mobile_extract",
    "_extracted_new",
    "src_extracted",
    "base",
    "halong-cruise-wp",
    "docs",
    "app/app",
    "components/components",
    "lib/lib",
    "scripts/scripts",
    "public/public",
    "prisma/prisma",
    "design-system/design-system",
    "design-tokens/design-tokens",
    "messages/messages",
    "i18n/i18n",
    "data/data"
  ]
}
